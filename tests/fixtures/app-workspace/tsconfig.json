{
    "compilerOptions": {
        "composite": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noUncheckedIndexedAccess": true,
        "strict": true,
        "jsx": "preserve",
        "importHelpers": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM", "WebWorker"],
        "baseUrl": "./",
        "paths": {
            "State/*": ["app/js/state/*"],
            "UiKit/*": ["app/js/ui-kit/*"],
            "App/*": ["app/js/*"],
            "Domain/*": ["app/js/domain/*"],
            "Theme/*": ["app/styles/*"],
            "Fields/*": ["app/js/ui-kit/components/fields/*"]
        }
    },
    "include": ["app/js/**/*.ts", "app/js/**/*.d.ts", "app/js/**/*.vue", "tests/**/*.ts"]
}
